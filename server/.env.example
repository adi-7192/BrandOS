PORT=4000

# Allowed CORS origins — comma-separated list of exact URLs (no wildcards).
# In production set to your deployed frontend URL, e.g. https://app.brandos.ai
# Leave unset in development (defaults to http://localhost:3000).
ALLOWED_ORIGINS=https://app.brandos.ai

# PostgreSQL via Supabase — paste the "Transaction pooler" connection string from
# your Supabase project → Settings → Database → Connection string.
# For production: use the limited-privilege brandos_app role created by 002_security.sql
# instead of the superuser (postgres). Replace the user and password below accordingly.
# Example: postgresql://brandos_app:STRONG_PASSWORD@localhost:5432/brandos
DATABASE_URL=postgresql://postgres:password@localhost:5432/brandos

# JWT — minimum 32 characters; generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_64_char_random_hex_secret_generated_by_command_above

# LinkedIn token encryption — minimum 32 characters; generate the same way as JWT_SECRET
# Used to AES-256-GCM encrypt LinkedIn access/refresh tokens before storing in the DB.
# Changing this value invalidates all existing LinkedIn connections (users must reconnect).
LINKEDIN_TOKEN_ENCRYPTION_KEY=replace_with_a_separate_64_char_random_hex_secret

# AI Provider — choose one: anthropic | openai | gemini
AI_PROVIDER=openai

# Anthropic — get your key at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — get your key at platform.openai.com
OPENAI_API_KEY=sk-proj-...

# Google Gemini — get your key at aistudio.google.com
GEMINI_API_KEY=

# Supabase — get these from your project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Supabase Storage bucket name (create in Supabase → Storage)
SUPABASE_STORAGE_BUCKET=brand-guidelines

# Gmail OAuth (optional for MVP)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:4000/api/auth/gmail/callback

# Resend inbound email
RESEND_API_KEY=re_...
RESEND_WEBHOOK_SECRET=whsec_...
RESEND_INBOUND_DOMAIN=eemeacalau.resend.app
